# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=sb_publishable_your_key
SUPABASE_SECRET_KEY=sb_secret_your_service_role_key

# Circle
CIRCLE_API_KEY=TEST_API_KEY:your_api_key
